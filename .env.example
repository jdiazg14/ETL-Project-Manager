
# Variables de entorno para ETL-Project-Manager (MySQL)

# Clave secreta para Flask
SECRET_KEY=your-secret-key

# URI de conexión a la base de datos MySQL
# Formato: mysql+pymysql://usuario:password@localhost/nombre_db
DATABASE_URL=mysql+pymysql://user:password@localhost/dbname

# Carpeta para archivos subidos
UPLOAD_FOLDER=uploads

# Tamaño máximo de archivo (bytes, por defecto 16MB)
MAX_CONTENT_LENGTH=16777216

# Cookies de sesión (opcional)
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
